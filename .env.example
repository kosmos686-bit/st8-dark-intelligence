# ST8 Dark Intelligence — Environment Variables
# Скопируй в .env и заполни значения

# ─── БАЗА ДАННЫХ ──────────────────────────────────────────────────
POSTGRES_DB=st8dark
POSTGRES_USER=st8
POSTGRES_PASSWORD=ЗАМЕНИ_НА_СИЛЬНЫЙ_ПАРОЛЬ

CLICKHOUSE_DB=st8dark
CLICKHOUSE_USER=st8
CLICKHOUSE_PASSWORD=ЗАМЕНИ_НА_СИЛЬНЫЙ_ПАРОЛЬ

REDIS_PASSWORD=ЗАМЕНИ_НА_СИЛЬНЫЙ_ПАРОЛЬ

# ─── БЕЗОПАСНОСТЬ ─────────────────────────────────────────────────
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ЗАМЕНИ_НА_32_БАЙТА_HEX

# ─── AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── PWA PUSH ─────────────────────────────────────────────────────
# Генерация: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=kosmos686@gmail.com

# ─── URLS ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.st8dark.ru
NEXT_PUBLIC_WS_URL=wss://api.st8dark.ru

# ─── ОКРУЖЕНИЕ ────────────────────────────────────────────────────
ENVIRONMENT=production
# development | production
